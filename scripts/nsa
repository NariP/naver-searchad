#!/usr/bin/env bash
# nsa — Keychain에서 키를 꺼내 환경변수로 채운 뒤 nsa.py 실행 (macOS)
#
# 사전 1회: 키 3개를 Keychain에 저장
#   security add-generic-password -U -a "$USER" -s NAVER_AD_API_KEY     -w '값'
#   security add-generic-password -U -a "$USER" -s NAVER_AD_SECRET_KEY  -w '값'
#   security add-generic-password -U -a "$USER" -s NAVER_AD_CUSTOMER_ID -w '값'
#
# 사용:  ./scripts/nsa campaigns
#        ./scripts/nsa stats --ids cmp-1 --since 2026-06-01 --until 2026-06-17
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# 이미 환경변수가 있으면 그대로 사용(코덱스/CI 등). 없으면 Keychain에서 채움.
load() {
  local name="$1"
  if [[ -n "${!name:-}" ]]; then return 0; fi
  local val
  if val="$(security find-generic-password -a "$USER" -s "$name" -w 2>/dev/null)"; then
    export "$name=$val"
  else
    echo "[nsa] Keychain에 $name 없음. 먼저 저장하세요:" >&2
    echo "      security add-generic-password -U -a \"\$USER\" -s $name -w '값'" >&2
    exit 1
  fi
}

load NAVER_AD_API_KEY
load NAVER_AD_SECRET_KEY
load NAVER_AD_CUSTOMER_ID

exec python3 "$DIR/nsa.py" "$@"
